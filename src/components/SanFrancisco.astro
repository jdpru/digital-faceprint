---
// A hidden Golden Gate microinteraction. Bringing the cursor near
// "San Francisco, CA" sweeps International Orange across the text with a
// slight wave; hovering the text itself reveals a couple of favorite SF spots.
interface Props {
  place?: string;
}
const { place = 'San Francisco, CA' } = Astro.props;
const letters = [...place];
---
<span class="sf-place">
  <span class="sf-hot"><span class="u-vh">{place}</span>{letters.map((ch, i) => (<span class="sf-letter" style={`--d:${i * 22}ms`} aria-hidden="true">{ch === ' ' ? ' ' : ch}</span>))}</span>
  <span class="sf-pop" role="tooltip" aria-hidden="true">
    <img class="sf-pop__badge" src="/gallery/sf/golden-gate.jpg" alt="" width="72" height="72" loading="lazy" />
    <p class="sf-pop__title">My favorite places in SF</p>
    <ul class="sf-pop__list">
      <li><a class="sf-pop__social" href="https://www.thesocialstudysf.com/" target="_blank" rel="noopener"><span class="sf-pop__the">the</span>Social Study</a></li>
      <li><span class="sf-pop__deyoung">de Young</span></li>
    </ul>
  </span>
</span>

<script>
  document.querySelectorAll<HTMLElement>('.sf-place').forEach((wrap) => {
    const hot = wrap.querySelector<HTMLElement>('.sf-hot');
    const pop = wrap.querySelector<HTMLElement>('.sf-pop');
    if (!hot || !pop) return;
    let hideTimer = 0;
    const show = () => {
      window.clearTimeout(hideTimer);
      pop.classList.add('is-shown');
      pop.setAttribute('aria-hidden', 'false');
    };
    const hide = () => {
      hideTimer = window.setTimeout(() => {
        pop.classList.remove('is-shown');
        pop.setAttribute('aria-hidden', 'true');
      }, 160);
    };
    hot.addEventListener('mouseenter', show);
    hot.addEventListener('mouseleave', hide);
    pop.addEventListener('mouseenter', () => window.clearTimeout(hideTimer));
    pop.addEventListener('mouseleave', hide);
  });
</script>
