---
import { site } from '../data/site';
import Socials from './Socials.astro';
---

<header class="hero wrap">
  <div class="portrait" id="portrait">
    <div class="portrait__inner" id="portraitInner">
      <img src={site.portrait.src} alt={site.portrait.alt} />
    </div>
    <div class="portrait__frame"></div>
  </div>

  <h1 set:html={site.name.replace(' ', '&nbsp;')} />
  <p class="lede">{site.lede}</p>

  <div class="hero__meta">
    {site.chips.map((chip) => <span class="chip">{chip}</span>)}
  </div>

  <Socials />
  <a class="hero__email" href={`mailto:${site.email}`}>email: {site.email}</a>

  <button class="scrolldn" id="scrolldn" aria-label="Scroll to about">
    <span class="arr">↓</span>
  </button>
</header>

<script>
  // Scroll cue → About
  const cue = document.getElementById('scrolldn');
  if (cue) {
    cue.addEventListener('click', () => {
      document.getElementById('about')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  // Subtle parallax: the portrait drifts slightly toward the cursor.
  (function () {
    const portrait = document.getElementById('portrait');
    const inner = document.getElementById('portraitInner');
    if (!portrait || !inner) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let mx = window.innerWidth / 2;
    let my = window.innerHeight / 2;
    const cur = { ix: 0, iy: 0 };

    window.addEventListener('mousemove', (ev) => {
      mx = ev.clientX;
      my = ev.clientY;
    });

    function loop() {
      const r = portrait.getBoundingClientRect();
      const cx = r.left + r.width / 2;
      const cy = r.top + r.height / 2;
      const dxp = (mx - cx) / window.innerWidth;
      const dyp = (my - cy) / window.innerHeight;
      const tx = Math.max(-1, Math.min(1, dxp)) * 7;
      const ty = Math.max(-1, Math.min(1, dyp)) * 7;
      cur.ix += (tx - cur.ix) * 0.08;
      cur.iy += (ty - cur.iy) * 0.08;
      inner.style.transform = `scale(1.06) translate(${cur.ix.toFixed(2)}px,${cur.iy.toFixed(2)}px)`;
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);
  })();
</script>
