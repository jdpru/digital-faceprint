---
interface Props {
  github: string;
  linkedin: string;
  twitter: string;
  email: string;
}

const { github, linkedin, twitter, email } = Astro.props;
---

<div class="nav-icons" aria-label="External links">
  <a href={github} target="_blank" rel="noreferrer" aria-label="GitHub">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .5C5.65.5.5 5.65.5 12A11.5 11.5 0 0 0 8.36 22.9c.58.1.79-.25.79-.56l-.01-2.18c-3.19.69-3.86-1.35-3.86-1.35-.52-1.31-1.27-1.66-1.27-1.66-1.03-.71.08-.7.08-.7 1.14.08 1.73 1.16 1.73 1.16 1.01 1.73 2.65 1.23 3.29.94.1-.73.4-1.23.72-1.51-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.17-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.76.11 3.05.73.8 1.17 1.83 1.17 3.08 0 4.41-2.69 5.39-5.25 5.67.41.35.77 1.03.77 2.08l-.01 3.08c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
  </a>
  <a href={linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6.94 8.5A1.56 1.56 0 1 1 6.94 5.38a1.56 1.56 0 0 1 0 3.12ZM8.5 18.5H5.37V9.5H8.5v9Zm5 0h-3.1V9.5h2.97v1.23h.04c.41-.78 1.42-1.6 2.93-1.6 3.13 0 3.71 2.06 3.71 4.73v4.64h-3.12v-4.11c0-.98-.02-2.24-1.37-2.24-1.37 0-1.58 1.07-1.58 2.17v4.18Z"/></svg>
  </a>
  <a href={twitter} target="_blank" rel="noreferrer" aria-label="Twitter">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M18.9 2H22l-6.77 7.74L23.2 22h-6.26l-4.9-6.42L6.42 22H3.31l7.24-8.27L.8 2h6.42l4.43 5.85L18.9 2Zm-1.1 18h1.73L6.3 3.9H4.44L17.8 20Z"/></svg>
  </a>
  <a href={`mailto:${email}`} aria-label="Email">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M3 5.75A2.75 2.75 0 0 1 5.75 3h12.5A2.75 2.75 0 0 1 21 5.75v12.5A2.75 2.75 0 0 1 18.25 21H5.75A2.75 2.75 0 0 1 3 18.25V5.75Zm2.2.25L12 11.1 18.8 6H5.2Zm13.05 1.17-5.7 4.28a.94.94 0 0 1-1.1 0l-5.7-4.28v11.08c0 .28.22.5.5.5h12.5c.28 0 .5-.22.5-.5V7.17Z"/></svg>
  </a>
</div>

<style>
  .nav-icons {
    display: flex;
    gap: 0.72rem;
    align-items: center;
  }

  .nav-icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15rem;
    height: 1.15rem;
    color: var(--muted);
    transition: color 180ms ease, transform 180ms ease;
  }

  .nav-icons a:hover {
    color: var(--accent);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .nav-icons svg {
    width: 100%;
    height: 100%;
  }
</style>
