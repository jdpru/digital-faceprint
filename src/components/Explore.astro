---
import { explore } from '../data/site';
---

<div class="explore">
  {explore.map((card) => (
    <a class="xcard" href={card.href}>
      <span class="xcard__num" aria-hidden="true">{card.num}</span>
      <h3>{card.title}</h3>
      <p>{card.blurb}</p>
      <span class="xcard__go" aria-hidden="true">→</span>
    </a>
  ))}
</div>
