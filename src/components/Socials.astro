---
import { site } from '../data/site';
---

<div class="socials" aria-label="Social links">
  <a href={site.links.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path fill="currentColor" d="M6.94 8.5A1.56 1.56 0 1 1 6.94 5.38a1.56 1.56 0 0 1 0 3.12ZM8.5 18.5H5.37V9.5H8.5v9Zm5 0h-3.1V9.5h2.97v1.23h.04c.41-.78 1.42-1.6 2.93-1.6 3.13 0 3.71 2.06 3.71 4.73v4.64h-3.12v-4.11c0-.98-.02-2.24-1.37-2.24-1.37 0-1.58 1.07-1.58 2.17v4.18Z" />
    </svg>
  </a>
  <a href={site.links.twitter} target="_blank" rel="noopener" aria-label="X (Twitter)">
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path fill="currentColor" d="M18.9 2H22l-6.77 7.74L23.2 22h-6.26l-4.9-6.42L6.42 22H3.31l7.24-8.27L.8 2h6.42l4.43 5.85L18.9 2Zm-1.1 18h1.73L6.3 3.9H4.44L17.8 20Z" />
    </svg>
  </a>
  <a href={site.links.osf} target="_blank" rel="noopener" aria-label="OSF">
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <text x="12" y="16" text-anchor="middle" font-family="var(--serif)" font-size="9.5" font-weight="600" fill="currentColor">OSF</text>
    </svg>
  </a>
</div>
