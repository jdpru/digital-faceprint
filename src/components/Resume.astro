---
import { experience, education, educationSchool, site } from '../data/site';
---

<div class="resume">
  <div><span class="label">Work</span></div>
  <div>
    <div class="resume__list">
      {experience.map((e) => (
        <div class="rrow">
          <button class="rrow__main" type="button" aria-expanded="false">
            <span class="rrow__yr">{e.years}</span>
            <span class="rrow__mid">
              <span class="rrow__role">{e.role}</span>
              <span class="rrow__org">{e.org}<span class="place">{e.place}</span></span>
            </span>
            <span class="rrow__toggle" aria-hidden="true"></span>
          </button>
          <div class="rrow__detail">
            <div class="rrow__detail-in">
              <div class="rrow__photo" aria-hidden="true"><span>Photo</span></div>
              <div class="rrow__desc">
                {e.description.map((p) => <p>{p}</p>)}
                <div class="rrow__tags">
                  {e.tags.map((t) => <span>{t}</span>)}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="edu">
      <span class="label edu__label">Education</span>
      <p class="edu__school">{educationSchool}</p>
      <div class="edu__list">
        {education.map((ed) => (
          <div class="eduline">
            <div class="edu__deg">
              <span class="deg">{ed.degree}</span>
              <span class="thesis"><em>{ed.thesis}</em></span>
              {ed.award && (
                <span class="award">
                  {ed.awardHref
                    ? <a href={ed.awardHref} target="_blank" rel="noopener">{ed.award}</a>
                    : ed.award}
                </span>
              )}
            </div>
            <span class="meta">{ed.gpa} · {ed.year}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="resume__cta">
      <a class="btnlink" href={site.links.cv} target="_blank" rel="noopener">
        Full curriculum vitæ <span class="ar">↓</span>
      </a>
    </div>
  </div>
</div>

<script>
  // Click (or keyboard) pins a row open; hover previews it via CSS.
  document.querySelectorAll('.rrow__main').forEach((btn) => {
    btn.addEventListener('click', () => {
      const row = btn.closest('.rrow');
      if (!row) return;
      const open = row.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });
</script>
