---
import { experience, education, educationSchool } from '../data/site';
---

<div class="resume">
  <div><span class="label">Work</span></div>
  <div>
    <div class="resume__list-head">
      <button class="expand-all" type="button" aria-expanded="false">Expand all</button>
    </div>
    <div class="resume__list">
      {experience.map((e) => (
        <div class="rrow">
          <div class="rrow__main">
            <span class="rrow__yr">{e.years}</span>
            <span class="rrow__mid">
              {e.href
                ? <a class="rrow__role rrow__role--link" href={e.href}>{e.role}</a>
                : <span class="rrow__role">{e.role}</span>}
              <span class="rrow__org">{e.org}<span class="place">{e.place}</span></span>
            </span>
            <button class="rrow__ind" type="button" aria-pressed="false" aria-label={`Keep ${e.role} open`}>
              <span class="rrow__toggle" aria-hidden="true"></span>
            </button>
          </div>
          <div class="rrow__detail">
            <div class="rrow__detail-in">
              {e.photos && e.photos.length > 0 && (
                <div class="rrow__photos">
                  {e.photos.map((p) => (
                    <div class="rrow__photo">
                      <img
                        src={p.src}
                        alt={p.alt}
                        loading="lazy"
                        style={p.objectPosition ? `object-position: ${p.objectPosition}` : undefined}
                      />
                    </div>
                  ))}
                </div>
              )}
              <div class="rrow__desc">
                {e.description.map((p) =>
                  typeof p === 'string' ? <p>{p}</p> : <p set:html={p.html} />
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div><span class="label">Education</span></div>
  <div class="edu">
    <p class="edu__school">{educationSchool}</p>
    <div class="edu__list">
      {education.map((ed) => (
        <div class="eduline">
          <div class="edu__deg">
            <span class="deg">{ed.degree}</span>
            <span class="thesis"><em>{ed.thesis}</em></span>
            {ed.papers && ed.papers.map((p) => (
              <span class="thesis"><em>{p.title}</em></span>
            ))}
            {ed.awards && ed.awards.length > 0 && (
              <div class="edu__awards">
                {ed.awards.map((a) => (
                  <span class="award">
                    {a.href
                      ? <a href={a.href} target="_blank" rel="noopener">{a.label}</a>
                      : a.label}
                  </span>
                ))}
              </div>
            )}
          </div>
          <span class="meta">{ed.gpa} · {ed.year}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  const rows = () => [...document.querySelectorAll<HTMLElement>('.rrow')];
  const expandBtn = document.querySelector<HTMLButtonElement>('.expand-all');

  function syncExpandLabel() {
    if (!expandBtn) return;
    const all = rows();
    const allOpen = all.length > 0 && all.every((r) => r.classList.contains('is-open'));
    expandBtn.textContent = allOpen ? 'Collapse all' : 'Expand all';
    expandBtn.setAttribute('aria-expanded', allOpen ? 'true' : 'false');
  }

  // The pin control (＋ / pin icon) locks a row open; hover previews it via CSS.
  document.querySelectorAll<HTMLButtonElement>('.rrow__ind').forEach((btn) => {
    btn.addEventListener('click', () => {
      const row = btn.closest('.rrow');
      if (!row) return;
      const open = row.classList.toggle('is-open');
      btn.setAttribute('aria-pressed', open ? 'true' : 'false');
      syncExpandLabel();
    });
  });

  expandBtn?.addEventListener('click', () => {
    const all = rows();
    const shouldOpen = !all.every((r) => r.classList.contains('is-open'));
    all.forEach((row) => {
      row.classList.toggle('is-open', shouldOpen);
      row.querySelector('.rrow__ind')?.setAttribute('aria-pressed', shouldOpen ? 'true' : 'false');
    });
    syncExpandLabel();
  });
</script>
