---
import { experience, education, educationSchool } from '../data/site';
---

<div class="resume">
  <div class="resume__head">
    <span class="label">Work</span>
    <button class="expand-all" type="button" aria-expanded="false">Expand all</button>
  </div>
  <div>
    <div class="resume__list">
      {experience.map((e) => {
        const sf = e.place.startsWith('San Francisco');
        return (
        <div class="rrow">
          <button class="rrow__main" type="button" aria-expanded="false">
            <span class="rrow__yr">{e.years}</span>
            <span class="rrow__mid">
              <span class="rrow__role">{e.role}</span>
              <span class="rrow__org">{e.org}<span class="place">{sf
                ? (<><span class="sf-hot">San Francisco<svg class="sf-hot__bridge" viewBox="0 0 100 16" preserveAspectRatio="none" aria-hidden="true"><path class="sf-hot__cable" d="M0,13 Q22,1 50,7 T100,13" fill="none" vector-effect="non-scaling-stroke"/><path class="sf-hot__deck" d="M0,13 H100" fill="none" vector-effect="non-scaling-stroke"/><path class="sf-hot__tower" d="M22,13 V2 M78,13 V2" fill="none" vector-effect="non-scaling-stroke"/></svg></span>{e.place.replace('San Francisco', '')}</>)
                : e.place}</span></span>
            </span>
            <span class="rrow__ind" aria-hidden="true">
              <span class="rrow__pinlabel">Pinned</span>
              <span class="rrow__toggle"></span>
            </span>
          </button>
          {sf && (
            <div class="sf-pop" role="tooltip" aria-hidden="true">
              <svg class="sf-pop__bridge" viewBox="0 0 220 72" fill="none" aria-hidden="true">
                <path d="M0,60 H220" class="sf-pop__deck"/>
                <path d="M52,60 V15 M168,60 V15" class="sf-pop__tower"/>
                <path d="M3,58 Q52,15 110,33 Q168,15 217,58" class="sf-pop__cable"/>
                <path d="M28,49 V60 M82,25 V60 M110,33 V60 M138,25 V60 M192,49 V60" class="sf-pop__hangers"/>
              </svg>
              <p class="sf-pop__title">My favorite places in SF</p>
              <ul class="sf-pop__list">
                <li><a href="https://www.thesocialstudysf.com/" target="_blank" rel="noopener">The Social Study</a></li>
                <li><a href="https://www.famsf.org/visit/de-young" target="_blank" rel="noopener">de Young</a></li>
              </ul>
            </div>
          )}
          <div class="rrow__detail">
            <div class="rrow__detail-in">
              {e.photos && e.photos.length > 0 && (
                <div class="rrow__photos">
                  {e.photos.map((p) => (
                    <div class="rrow__photo">
                      <img src={p.src} alt={p.alt} loading="lazy" />
                    </div>
                  ))}
                </div>
              )}
              <div class="rrow__body">
                <div class="rrow__desc">
                  {e.description.map((p) => <p>{p}</p>)}
                </div>
                {e.href && (
                  <a class="rrow__more" href={e.href}>Read the write-up →</a>
                )}
              </div>
            </div>
          </div>
        </div>
        );
      })}
    </div>
  </div>

  <div><span class="label">Education</span></div>
  <div class="edu">
    <p class="edu__school">{educationSchool}</p>
    <div class="edu__list">
      {education.map((ed) => (
        <div class="eduline">
          <div class="edu__deg">
            <span class="deg">{ed.degree}</span>
            <span class="thesis"><em>{ed.thesis}</em></span>
            {ed.award && (
              <span class="award">
                {ed.awardHref
                  ? <a href={ed.awardHref} target="_blank" rel="noopener">{ed.award}</a>
                  : ed.award}
              </span>
            )}
          </div>
          <span class="meta">{ed.gpa} · {ed.year}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  const rows = () => [...document.querySelectorAll<HTMLElement>('.rrow')];
  const expandBtn = document.querySelector<HTMLButtonElement>('.expand-all');

  function syncExpandLabel() {
    if (!expandBtn) return;
    const all = rows();
    const allOpen = all.length > 0 && all.every((r) => r.classList.contains('is-open'));
    expandBtn.textContent = allOpen ? 'Collapse all' : 'Expand all';
    expandBtn.setAttribute('aria-expanded', allOpen ? 'true' : 'false');
  }

  // Click (or keyboard) pins a row open; hover previews it via CSS.
  document.querySelectorAll<HTMLButtonElement>('.rrow__main').forEach((btn) => {
    btn.addEventListener('click', () => {
      const row = btn.closest('.rrow');
      if (!row) return;
      const open = row.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      syncExpandLabel();
    });
  });

  expandBtn?.addEventListener('click', () => {
    const all = rows();
    const shouldOpen = !all.every((r) => r.classList.contains('is-open'));
    all.forEach((row) => {
      row.classList.toggle('is-open', shouldOpen);
      row.querySelector('.rrow__main')?.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
    });
    syncExpandLabel();
  });

  // "San Francisco" hover reveals a small popover of favorite places.
  document.querySelectorAll<HTMLElement>('.sf-hot').forEach((hot) => {
    const row = hot.closest<HTMLElement>('.rrow');
    const pop = row?.querySelector<HTMLElement>('.sf-pop');
    if (!row || !pop) return;
    let hideTimer = 0;

    const show = () => {
      window.clearTimeout(hideTimer);
      const hotR = hot.getBoundingClientRect();
      const rowR = row.getBoundingClientRect();
      const maxLeft = rowR.width - pop.offsetWidth - 2;
      let left = hotR.left - rowR.left;
      if (left > maxLeft) left = Math.max(0, maxLeft);
      pop.style.left = Math.round(left) + 'px';
      pop.style.top = Math.round(hotR.bottom - rowR.top + 8) + 'px';
      pop.classList.add('is-shown');
      pop.setAttribute('aria-hidden', 'false');
    };
    const hide = () => {
      hideTimer = window.setTimeout(() => {
        pop.classList.remove('is-shown');
        pop.setAttribute('aria-hidden', 'true');
      }, 160);
    };

    hot.addEventListener('mouseenter', show);
    hot.addEventListener('mouseleave', hide);
    pop.addEventListener('mouseenter', () => window.clearTimeout(hideTimer));
    pop.addEventListener('mouseleave', hide);
  });
</script>
