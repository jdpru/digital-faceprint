---
import Layout from '../../layouts/Layout.astro';
import { publications } from '../../data/site';
---

<Layout
  title="Publications — JD Pruett"
  description="Papers and technical writing by JD Pruett."
>
  <main class="wrap">
    <section class="subhero">
      <span class="eyebrow">Publications</span>
      <h1>Papers &amp; <em>technical writing</em></h1>
      <p>A selective list for now — the structure is here for a fuller bibliography over time.</p>
    </section>

    <div class="publist">
      {publications.map((p) => (
        <article class="pubrow">
          <div>
            <span class="venue">{p.venue}</span>
            <h2>{p.title}</h2>
            <p class="blurb">{p.blurb}</p>
          </div>
          <div class="year">{p.year}</div>
        </article>
      ))}
    </div>
  </main>
</Layout>
