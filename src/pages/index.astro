---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Resume from '../components/Resume.astro';
import Explore from '../components/Explore.astro';
import { site } from '../data/site';
---

<Layout>
  <Hero />

  <main class="wrap">
    <!-- ABOUT -->
    <section id="about" class="section" aria-labelledby="about-h">
      <div class="about-body">
        <div>
          <span class="eyebrow muted" id="about-h">About</span>
          <dl class="about-facts" style="margin-top:18px;">
            {site.about.facts.map((f) => (
              <>
                <dt>{f.k}</dt>
                <dd>{f.v}</dd>
              </>
            ))}
          </dl>
        </div>
        <div class="prose">
          {site.about.prose.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- RÉSUMÉ -->
    <section id="resume" class="section" aria-labelledby="resume-h">
      <div class="sec-head">
        <div><span class="eyebrow">01 — Résumé</span></div>
        <div>
          <h2 id="resume-h">The short version</h2>
          <p class="lead">Four roles across research, philanthropy, and the field — plus two degrees from Stanford.</p>
        </div>
      </div>
      <Resume />
    </section>

    <!-- EXPLORE -->
    <section id="explore" class="section" aria-labelledby="explore-h">
      <div class="sec-head">
        <div><span class="eyebrow">02 — Explore</span></div>
        <div>
          <h2 id="explore-h">Three shelves</h2>
          <p class="lead">The work I'm paid for, the work I'm not, and what I'm reading. <em>Open any one.</em></p>
        </div>
      </div>
      <Explore />
    </section>
  </main>
</Layout>
