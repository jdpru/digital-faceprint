---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Resume from '../components/Resume.astro';
import Explore from '../components/Explore.astro';
import { site } from '../data/site';
---

<Layout>
  <Hero />

  <main class="wrap">
    <!-- ABOUT -->
    <section id="about" class="section" aria-label="About">
      <div class="about-body">
        <div>
          <dl class="about-facts">
            <dt>Based</dt>
            <dd>{site.about.based}</dd>

            <dt>Momentarily Occupied By</dt>
            <dd>
              <ul class="about-list about-links">
                {site.about.occupied.items.map((i) => (
                  <li><a href={i.href} target="_blank" rel="noopener">{i.label}</a></li>
                ))}
              </ul>
            </dd>

            <dt>Methods</dt>
            <dd>{site.about.methods}</dd>

            <dt>Mentors</dt>
            <dd>
              <ul class="about-stack">
                {site.about.mentors.map((m) => (
                  <li><a href={m.href} target="_blank" rel="noopener">{m.name}</a></li>
                ))}
              </ul>
            </dd>
          </dl>
        </div>
        <div class="prose">
          {site.about.prose.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section id="resume" class="section" aria-label="Work">
      <Resume />
    </section>

    <!-- WORKS -->
    <section id="explore" class="section" aria-label="Works">
      <div class="works-head"><span class="label">Works</span></div>
      <Explore />
    </section>
  </main>
</Layout>
