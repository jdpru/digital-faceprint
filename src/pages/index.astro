---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import { site, education, work, writing } from '../data/site';

const selectedWork = work.slice(0, 4);
---

<Layout>
  <Hero />

  <main class="wrap">
    <!-- ABOUT -->
    <section id="about">
      <div class="about-body">
        <div class="about-side">
          <span class="eyebrow muted">About</span>
          <div style="margin-top:18px;">
            {site.about.facts.map((f) => (
              <><span class="k">{f.k}</span>{f.v}</>
            ))}
          </div>
        </div>
        <div class="prose">
          {site.about.prose.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience">
      <div class="sec-head">
        <div><span class="eyebrow">01 — Experience</span></div>
        <div>
          <h2>An interactive résumé</h2>
          <p class="lead">Roles across research, philanthropy, and the field. <em>Expand any line</em> to read more.</p>
        </div>
      </div>

      <Experience />

      <div class="edu">
        <div><span class="eyebrow muted">Education</span></div>
        <div class="edu__list">
          {education.map((e) => (
            <div class="edu__item">
              <div class="edu__deg">{e.degree}
                <span class="thesis">Thesis — <em>{e.thesis}</em>{e.award && <> · <span class="award">{e.award}</span></>}</span>
              </div>
              <div class="edu__meta">{e.school} · {e.gpa}<br />{e.year}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SELECTED WORK -->
    <section id="work">
      <div class="sec-head">
        <div><span class="eyebrow">02 — Selected work</span></div>
        <div>
          <h2>Projects &amp; papers</h2>
          <p class="lead">Where survey methods, neuroscience, and machine learning meet — usually with code attached.</p>
          <a class="sec-head__more" href="/projects/">All projects &amp; papers →</a>
        </div>
      </div>

      <div class="works">
        {selectedWork.map((w) => (
          <article class="work">
            <div class="work__top"><span class="work__kind">{w.kind}</span><span class="work__status">{w.status}</span></div>
            <h3>{w.title}</h3>
            <p>{w.summary}</p>
            <div class="work__links">
              {w.links.map((l) => (
                l.href
                  ? <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
                  : <a class="dead">{l.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- WRITING -->
    <section id="writing">
      <div class="clip">
        <div><span class="eyebrow">03 — Writing</span></div>
        <div class="writing-list">
          {writing.map((w) => (
            <a class="writing-card" href={w.href} target="_blank" rel="noopener">
              <div class="outlet">{w.outlet}</div>
              <h3>{w.title}</h3>
              <div class="by">{w.by}</div>
              <span class="arrow">Read →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
