---
import Layout from '../../layouts/Layout.astro';
import { personalProjects } from '../../data/site';

// Muted, in-palette gradients standing in for each pinned idea's "photo".
const tints = [
  'linear-gradient(150deg, #33445e 0%, #5c7392 55%, #8a9bb4 100%)',
  'linear-gradient(150deg, #3f5f45 0%, #6f9066 55%, #a7bd8f 100%)',
  'linear-gradient(150deg, #2c5f6d 0%, #4f8ea0 55%, #93c0cc 100%)',
  'linear-gradient(150deg, #5f4560 0%, #8a6c8c 55%, #b79db3 100%)',
  'linear-gradient(150deg, #6d5636 0%, #9a7f52 55%, #c2ab84 100%)',
  'linear-gradient(150deg, #45506d 0%, #6b789e 55%, #9aa6c4 100%)',
];
const rot = ['-2.4deg', '1.9deg', '-1.3deg', '2.5deg', '-1.9deg', '1.3deg'];
---

<Layout
  title="Fun Stuff — JD Pruett"
  description="A corkboard of side projects, pinned up and never quite finished."
>
  <main class="wrap">
    <section class="board-head">
      <p class="label">Fun Stuff</p>
      <h1>Pinned up, <em>never quite finished.</em></h1>
    </section>

    <div class="board">
      {personalProjects.map((w, i) => (
        <button
          class="pin-card"
          type="button"
          data-i={i}
          aria-haspopup="dialog"
          style={`--rot:${rot[i % rot.length]}`}
        >
          <span class="pin" aria-hidden="true"></span>
          <span class="pin-card__photo" style={`background:${tints[i % tints.length]}`}></span>
          <span class="pin-card__cap">{w.caption ?? w.title}</span>
        </button>
      ))}
    </div>

    <div class="pin-modal" hidden>
      <div class="pin-modal__backdrop" data-close></div>
      <div class="pin-modal__panel" role="dialog" aria-modal="true" aria-label="Project detail">
        <button class="pin-modal__close" type="button" data-close aria-label="Close">
          <svg viewBox="0 0 20 20" width="18" height="18" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        </button>
        <div class="pin-modal__body">
          {personalProjects.map((w, i) => (
            <article class="pin-detail" data-i={i} hidden>
              <p class="pin-detail__meta"><span>{w.kind}</span><span>{w.status}</span></p>
              <h2>{w.title}</h2>
              <p class="pin-detail__sum">{w.summary}</p>
              {w.video && (
                <div class="prow__video">
                  <iframe
                    data-src={`https://www.youtube-nocookie.com/embed/${w.video}`}
                    title={`${w.title} — walkthrough`}
                    loading="lazy"
                    allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
              )}
              {w.links.length > 0 && (
                <div class="pin-detail__links">
                  {w.links.map((l) => (
                    l.href
                      ? <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
                      : <span class="dead">{l.label}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const modal = document.querySelector<HTMLElement>('.pin-modal');
  if (modal) {
    const details = [...document.querySelectorAll<HTMLElement>('.pin-detail')];

    const loadVideos = (detail: HTMLElement) => {
      detail.querySelectorAll<HTMLIFrameElement>('iframe[data-src]').forEach((f) => {
        if (f.src !== f.dataset.src) f.src = f.dataset.src || '';
      });
    };
    const stopVideos = () => {
      modal.querySelectorAll<HTMLIFrameElement>('iframe[data-src]').forEach((f) => {
        f.src = '';
      });
    };

    const open = (i: string) => {
      details.forEach((d) => (d.hidden = d.dataset.i !== i));
      const active = details.find((d) => d.dataset.i === i);
      if (active) loadVideos(active);
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      modal.querySelector<HTMLElement>('.pin-modal__close')?.focus();
    };
    const close = () => {
      stopVideos();
      modal.hidden = true;
      document.body.style.overflow = '';
    };

    document.querySelectorAll<HTMLButtonElement>('.pin-card').forEach((card) => {
      card.addEventListener('click', () => open(card.dataset.i || '0'));
    });
    modal.querySelectorAll<HTMLElement>('[data-close]').forEach((el) => {
      el.addEventListener('click', close);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  }
</script>
