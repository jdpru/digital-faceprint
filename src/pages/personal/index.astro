---
import Layout from '../../layouts/Layout.astro';
import { personal, reading } from '../../data/site';
---

<Layout
  title="Personal — JD Pruett"
  description="Personal notes, interests, and a running reading list."
>
  <main class="wrap">
    <section class="subhero">
      <span class="eyebrow">Personal</span>
      <h1>Outside the <em>technical work</em></h1>
      <p>Writing, interfaces, belief formation, and the strange ways people move through institutions, products, and norms.</p>
    </section>

    <div class="prose-page">
      {personal.map((p) => <p>{p}</p>)}
    </div>

    <section>
      <div class="sec-head">
        <div><span class="eyebrow">Reading</span></div>
        <div>
          <h2>A running shelf</h2>
          <p class="lead">Books and papers worth your time — and a note on why.</p>
        </div>
      </div>
      <div class="readlist">
        {reading.map((b) => (
          <div class="bookrow">
            <div>
              <span class="bookrow__title">{b.title}</span><span class="bookrow__author">{b.author}</span>
            </div>
            <div class="bookrow__note">{b.note}</div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>
