---
import Layout from '../../layouts/Layout.astro';
import { personal, personalProjects } from '../../data/site';
---

<Layout
  title="Personal Projects — JD Pruett"
  description="Experiments, tools, and side projects built out of curiosity."
>
  <main class="wrap">
    <section class="subhero">
      <span class="eyebrow">Personal</span>
      <h1>Built for <em>curiosity</em></h1>
      <p>The things I make for no reason but my own interest — experiments, tools, and happy dead-ends.</p>
    </section>

    <div class="prose-page">
      {personal.map((p) => <p>{p}</p>)}
    </div>

    <div class="rows">
      {personalProjects.map((w) => (
        <article class="prow">
          <div class="prow__meta">
            <span class="prow__kind">{w.kind}</span><span class="prow__status">{w.status}</span>
          </div>
          <h2>{w.title}</h2>
          <p>{w.summary}</p>
          <div class="prow__links">
            {w.links.map((l) => (
              l.href
                ? <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
                : <a class="dead">{l.label}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>
