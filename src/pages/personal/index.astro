---
import Layout from '../../layouts/Layout.astro';
import { personal, personalProjects } from '../../data/site';
---

<Layout
  title="Fun Stuff — JD Pruett"
  description="Time well spent, perhaps better spent elsewhere."
>
  <main class="wrap">
    <section class="subhero">
      <h1>Fun Stuff</h1>
      <p>time well spent, though perhaps spent better elsewhere.</p>
    </section>

    <div class="prose-page">
      {personal.map((p) => <p>{p}</p>)}
    </div>

    <div class="rows">
      {personalProjects.map((w) => (
        <article class="prow">
          <div class="prow__meta">
            <span class="prow__kind">{w.kind}</span><span class="prow__status">{w.status}</span>
          </div>
          <h2>{w.title}</h2>
          <p>{w.summary}</p>
          {w.video && (
            <div class="prow__video">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${w.video}`}
                title={`${w.title} — walkthrough`}
                loading="lazy"
                allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          )}
          <div class="prow__links">
            {w.links.map((l) => (
              l.href
                ? <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
                : <span class="dead">{l.label}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>
