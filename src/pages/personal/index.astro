---
import Layout from '../../layouts/Layout.astro';
import { now, personal } from '../../data/site';
---

<Layout
  title="Personal — JD Pruett"
  description="Personal notes and interests of JD Pruett."
  active="personal"
>
  <section class="section">
    <p class="eyebrow">Personal</p>
    <h1>Interests outside the technical work</h1>
    <p class="lede">
      Writing, interfaces, belief formation, and the strange ways people move through institutions,
      products, and norms.
    </p>
  </section>

  <section class="section">
    <div class="plain-list">
      {personal.map((item) => (
        <article class="plain-item">
          <p class="body-large">{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="section-label">Now</p>
      <h2>Current preoccupations</h2>
    </div>
    <ul class="soft-list body-large">
      {now.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>
</Layout>
