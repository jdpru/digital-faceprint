---
import Layout from '../../layouts/Layout.astro';
import { work } from '../../data/site';
---

<Layout
  title="Projects & papers — JD Pruett"
  description="Projects and papers across survey methodology, neuroscience, and machine learning."
>
  <main class="wrap">
    <section class="subhero">
      <span class="eyebrow">Selected work</span>
      <h1>Projects &amp; <em>papers</em></h1>
      <p>Where survey methods, neuroscience, and machine learning meet — usually with code attached.</p>
    </section>

    <div class="projects">
      {work.map((w) => (
        <article class="prow">
          <div>
            <span class="prow__kind">{w.kind}</span><span class="prow__status">{w.status}</span>
          </div>
          <h2>{w.title}</h2>
          <p>{w.summary}</p>
          <div class="prow__links">
            {w.links.map((l) => (
              l.href
                ? <a href={l.href} target="_blank" rel="noopener">{l.label}</a>
                : <a class="dead">{l.label}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>
