---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'JD Pruett',
  description = 'Engineer and researcher working on AI systems, measurement, and applied data infrastructure.',
} = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/me/', label: 'About' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Neucha&family=Roboto+Condensed:wght@400;700&family=Source+Code+Pro:wght@400;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div id="main">
      <header class="site-header">
        <div class="author">
          <a class="author__logo" href="/" title="Home">
            <svg class="sketch-avatar" width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="116" height="116" rx="60" stroke="currentColor" stroke-width="2.5"/>
              <!-- hair -->
              <path d="M35 45c2-15 12-24 25-24s23 9 25 24" stroke="currentColor" stroke-width="2" fill="none"/>
              <path d="M32 50c0-4 2-8 5-11" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M88 50c0-4-2-8-5-11" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <!-- face outline -->
              <path d="M37 52c0 0-2 22 5 32s15 14 18 14s10-4 18-14s5-32 5-32" stroke="currentColor" stroke-width="2" fill="none"/>
              <!-- eyes -->
              <circle cx="48" cy="58" r="2.5" fill="currentColor"/>
              <circle cx="72" cy="58" r="2.5" fill="currentColor"/>
              <!-- eyebrows -->
              <path d="M43 53c2-2 5-3 8-2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M77 53c-2-2-5-3-8-2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <!-- nose -->
              <path d="M58 62c-1 4-1 8 2 10" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <!-- mouth -->
              <path d="M50 76c3 4 8 5 11 5s8-1 11-5" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <!-- glasses -->
              <rect x="40" y="52" width="16" height="12" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <rect x="64" y="52" width="16" height="12" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M56 58h8" stroke="currentColor" stroke-width="1.5"/>
              <!-- headphones hint -->
              <path d="M33 55c-3 0-5 3-5 7s2 7 5 7" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M87 55c3 0 5 3 5 7s-2 7-5 7" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
          </a>
          <div class="author__text">
            <a href="/" class="author__name">JD Pruett</a>
            <nav class="author__nav">
              {navItems.map((item) => (
                <a href={item.href} class={pathname === item.href ? 'active' : ''}>{item.label}</a>
              ))}
            </nav>
            <div class="author__links">
              <a href="https://github.com/jdpru" target="_blank" rel="noreferrer" aria-label="GitHub">
                <svg viewBox="0 0 16 16" width="18" height="18"><path fill="currentColor" d="M8 0C3.58 0 0 3.582 0 8c0 3.535 2.292 6.533 5.47 7.59.4.075.547-.172.547-.385 0-.19-.007-.693-.01-1.36-2.226.483-2.695-1.073-2.695-1.073-.364-.924-.89-1.17-.89-1.17-.725-.496.056-.486.056-.486.803.056 1.225.824 1.225.824.714 1.223 1.873.87 2.33.665.072-.517.278-.87.507-1.07-1.777-.2-3.644-.888-3.644-3.953 0-.873.31-1.587.823-2.147-.083-.202-.358-1.015.077-2.117 0 0 .672-.215 2.2.82.638-.178 1.323-.266 2.003-.27.68.004 1.364.092 2.003.27 1.527-1.035 2.198-.82 2.198-.82.437 1.102.163 1.915.08 2.117.513.56.823 1.274.823 2.147 0 3.073-1.87 3.75-3.653 3.947.287.246.543.735.543 1.48 0 1.07-.01 1.933-.01 2.195 0 .215.144.463.55.385C13.71 14.53 16 11.534 16 8c0-4.418-3.582-8-8-8"/></svg>
              </a>
              <a href="https://www.linkedin.com/in/jdpruett/" target="_blank" rel="noreferrer" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>&copy; {new Date().getFullYear()} JD Pruett</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  /* ======================================
     TOKENS — Jamie Wong palette
     ====================================== */
  :root {
    --text: #333;
    --text-muted: #828282;
    --text-light: #4f4f4f;
    --bg: #fff;
    --accent: #ff6d6d;
    --accent-hover: #e55555;
    --border: #e0e0e0;
    --code-bg: #f6f6f6;
    --max-width: 720px;
  }

  /* ======================================
     RESET & BASE
     ====================================== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    font-family: 'Roboto Condensed', 'Arial Narrow', 'Helvetica Neue', sans-serif;
    font-size: 19px;
    line-height: 1.6;
    color: var(--text);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
  }

  body { margin: 0; }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Neucha', 'Noteworthy', 'Comic Sans MS', cursive;
    line-height: 1.35;
    color: var(--text);
  }

  h1 { font-size: 2.1rem; margin-bottom: 0.5rem; }
  h2 { font-size: 1.55rem; color: var(--text-light); margin: 2.5rem 0 0.75rem; }
  h3 { font-size: 1.25rem; color: var(--text-muted); margin: 1.5rem 0 0.5rem; }

  p { margin-bottom: 1.25rem; }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: border-color 150ms ease;
  }

  a:hover {
    border-bottom: 1px solid var(--accent);
  }

  strong { font-weight: 700; }
  em { font-style: italic; }
  img { max-width: 100%; display: block; }

  code {
    font-family: 'Source Code Pro', monospace;
    font-size: 0.88em;
    color: var(--text-light);
    background: var(--code-bg);
    padding: 0.15em 0.35em;
    border-radius: 3px;
  }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  ul, ol {
    padding-left: 1.5em;
    margin-bottom: 1.25rem;
  }

  li { margin-bottom: 0.5rem; }

  li ul { margin-top: 0.4rem; margin-bottom: 0; }
  li ul li { font-size: 0.92rem; color: var(--text-muted); }

  /* ======================================
     LAYOUT
     ====================================== */
  #main {
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  main > * + * { margin-top: 0; }

  /* ======================================
     HEADER / AUTHOR
     ====================================== */
  .site-header {
    margin-bottom: 2.5rem;
  }

  .author {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .author__logo {
    flex-shrink: 0;
    color: var(--text);
    transition: color 200ms ease;
  }

  .author__logo:hover {
    color: var(--accent);
    border: none;
  }

  .sketch-avatar {
    display: block;
  }

  .author__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .author__name {
    font-family: 'Neucha', cursive;
    font-size: 1.85rem;
    color: var(--text);
    line-height: 1.1;
  }

  .author__name:hover {
    color: var(--accent);
    border: none;
  }

  .author__nav {
    display: flex;
    gap: 0.75rem;
  }

  .author__nav a {
    color: var(--text-muted);
    font-size: 0.92rem;
    font-weight: 700;
    padding: 0.15rem 0;
  }

  .author__nav a.active {
    color: var(--accent);
    border-bottom: 1.5px solid var(--accent);
  }

  .author__nav a:hover {
    color: var(--accent);
  }

  .author__links {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.15rem;
  }

  .author__links a {
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
  }

  .author__links a:hover {
    color: var(--accent);
    border: none;
  }

  /* ======================================
     CONTENT SECTIONS
     ====================================== */
  .intro-block {
    margin-bottom: 1.5rem;
  }

  .intro-block p {
    font-size: 1.05rem;
  }

  .section-heading {
    font-family: 'Neucha', cursive;
    font-size: 1.55rem;
    color: var(--text-light);
    margin: 0 0 0.75rem;
  }

  /* Project cards — Tania-style rich blocks */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 0;
    list-style: none;
    padding: 0;
  }

  .project-item {
    padding: 0;
  }

  .project-item h3 {
    font-family: 'Roboto Condensed', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.3rem;
  }

  .project-item p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  /* Publication list — nested style */
  .pub-list {
    list-style: disc;
    padding-left: 1.5em;
    margin-bottom: 1.25rem;
  }

  .pub-list li {
    margin-bottom: 0.65rem;
  }

  .pub-meta {
    display: block;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  /* Tag pills */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.35rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    background: rgba(255, 109, 109, 0.1);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ======================================
     FOOTER
     ====================================== */
  .site-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* ======================================
     RESPONSIVE
     ====================================== */
  @media (max-width: 600px) {
    html { font-size: 17px; }

    .author {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .sketch-avatar {
      width: 80px;
      height: 80px;
    }

    h1 { font-size: 1.7rem; }
    h2 { font-size: 1.35rem; }
  }
</style>
