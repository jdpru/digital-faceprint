---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — survey research, neuroscience, machine learning`,
  description = 'Personal site for JD Pruett — survey methodology, neuroscience, and machine-learning systems.',
} = Astro.props;

const nav = [
  { href: '/#about', label: 'About' },
  { href: '/#explore', label: 'Work' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..600;1,6..72,200..600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="topbar">
      <div class="wrap topbar__in">
        <a class="brand" href="/" aria-label={`${site.name} — home`}>
          <span>{site.name}<span class="dot">.</span></span>
          <svg class="brand__home" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M3 11.3 12 4l9 7.3" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M5.4 9.6V20h13.2V9.6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <nav class="nav" aria-label="Primary">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer" id="contact">
      <div class="wrap foot">
        <div><span class="eyebrow">Contact</span></div>
        <div>
          <h2>Get in touch</h2>
          <p>{site.contact.blurb}</p>
          <div class="foot-links">
            <a href={`mailto:${site.email}`}>Email <span class="ar">↗</span></a>
            <a href={site.links.linkedin} target="_blank" rel="noopener">LinkedIn <span class="ar">↗</span></a>
            <a href={site.links.cv} target="_blank" rel="noopener">Curriculum Vitae <span class="ar">↓</span></a>
            <a href={site.links.osf} target="_blank" rel="noopener">OSF <span class="ar">↗</span></a>
          </div>
          <p class="colophon">
            {site.contact.colophon.map((line) => <>{line}<br /></>)}
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
